{
    "version": 2,
    "framework": null,
    "functions": {
        "api/index.php": {
            "runtime": "vercel-php",
            "memory": 1024,
            "maxDuration": 10
        }
    },
    "routes": [
        { "src": "/build/(.*)", "dest": "/public/build/$1" },
        { "src": "/assets/(.*)", "dest": "/public/assets/$1" },
        { "src": "/(.*)", "dest": "/api/index.php" }
    ],
    "env": {
        "NODE_VERSION": "20"
    }
}
