{
    "version": 2,
    "framework": null,
    "functions": {
        "api/index.php": { "runtime": "vercel-php@0.7.0" }
    },
    "routes": [
        { "src": "/build/(.*)", "dest": "/static/$1" },
        { "src": "/(api/.*)", "dest": "/$1" },
        { "src": "/(.*)", "dest": "/api/index.php" }
    ]
}
